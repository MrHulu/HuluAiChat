# HuluChat Frontend Environment Variables
# Copy this file to .env.local for local development

# API Base URL (default: http://127.0.0.1:8765/api)
# Used for connecting to the Python FastAPI backend
VITE_API_BASE=http://127.0.0.1:8765/api

# Ollama Base URL (default: http://localhost:11434)
# Used for connecting to local Ollama instance
# VITE_OLLAMA_BASE_URL=http://localhost:11434
