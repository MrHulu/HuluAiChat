# HuluChat Backend Environment Variables
# Copy this file to .env for local development

# ====================
# API Keys (REQUIRED)
# ====================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ====================
# API Endpoints (OPTIONAL)
# ====================
# Leave empty to use default endpoints

# OpenAI API Base URL (optional, for custom endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek API Base URL (optional)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ====================
# Model Configuration (OPTIONAL)
# ====================
# Default model to use (gpt-4o-mini, deepseek-chat, etc.)
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_MODEL=deepseek-chat

# Default provider: "deepseek" | "openai" | "ollama"
# DEFAULT_PROVIDER=deepseek

# ====================
# Model Parameters (OPTIONAL)
# ====================
# TEMPERATURE=0.7
# TOP_P=1.0
# MAX_TOKENS=4096

# ====================
# Timeouts (OPTIONAL)
# ====================
# OpenAI/DeepSeek API timeout in seconds
# OPENAI_TIMEOUT=120

# HTTP connection timeout in seconds
# HTTP_CONNECT_TIMEOUT=10

# HTTP read timeout in seconds
# HTTP_READ_TIMEOUT=60

# ====================
# Ollama Configuration (OPTIONAL)
# ====================
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT=120

# ====================
# Server Configuration (OPTIONAL)
# ====================
# HOST=127.0.0.1
# PORT=8765
